# ====================================================================
# Gastos2 — variables de entorno
# Copia este archivo como .env.local para desarrollo local
# Y configúralas en Vercel (Settings → Environment Variables) en producción
# ====================================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=          # tu chat_id (lo obtenemos al primer mensaje)
TELEGRAM_WEBHOOK_SECRET=            # cualquier string aleatorio largo

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Groq (transcripción de audio) ---
GROQ_API_KEY=
GROQ_AUDIO_MODEL=whisper-large-v3-turbo

# --- Google Sheets ---
# El ID de tu Google Sheet (lo sacas de la URL: docs.google.com/spreadsheets/d/<ESTE_ID>/edit)
GOOGLE_SHEET_ID=
# Service account email (xxx@xxx.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Private key del service account (formato: "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n")
# IMPORTANTE: Vercel maneja \n bien si la pegas tal cual aparece en el JSON
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# --- Dashboard auth (Google OAuth) ---
# Configurar en console.cloud.google.com → OAuth 2.0 Client IDs (tipo: Web application)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Email autorizado para acceder al dashboard (solo este puede entrar)
ALLOWED_EMAIL=diego@fundacionrida.org
NEXTAUTH_SECRET=                    # genera con: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000  # en producción: https://tu-dominio.vercel.app

# --- App ---
TIMEZONE=America/Santiago
APP_BASE_URL=http://localhost:3000

# --- Cron (Vercel) ---
# Genera con: openssl rand -base64 24
# Vercel envía Authorization: Bearer <CRON_SECRET> al endpoint cron
CRON_SECRET=
